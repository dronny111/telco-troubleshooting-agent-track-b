# Copy to `.env` (or `source` directly) on the GPU box.

# ---- vLLM server side ------------------------------------------------------
# Where to download the model weights. Leave unset to use the default
# Hugging Face cache (~/.cache/huggingface).
export HF_HOME=/data/hf-cache

# If your model directory is private or you've pre-downloaded weights,
# point HF_HUB_OFFLINE=1 + HF_HUB_CACHE=/path to skip outbound calls.
# export HF_HUB_OFFLINE=1
# export HF_HUB_CACHE=/data/hf-cache

# Bind interface and port for vLLM. Default 0.0.0.0:8000.
export VLLM_HOST=0.0.0.0
export VLLM_PORT=8000

# GPU selection (CUDA_VISIBLE_DEVICES style). 0 for single GPU.
export CUDA_VISIBLE_DEVICES=0

# Tensor parallelism — set to the number of GPUs in CUDA_VISIBLE_DEVICES.
export TENSOR_PARALLEL=1

# Max prompt+output tokens. Track B prompts are <2K; 8192 is generous.
export MAX_MODEL_LEN=8192

# bf16 (default) or fp16 or fp8 — lowercase. fp8 needs a quantised
# checkpoint or --kv-cache-dtype fp8 only.
export DTYPE=bfloat16

# Optional quantization (e.g. awq, gptq, fp8). Leave empty for full bf16.
export QUANTIZATION=

# Server-side bearer token (the agent client sends this). Use any
# non-empty string; vLLM accepts whatever as long as the client matches.
export VLLM_API_KEY=local-dev-key


# ---- Agent client side -----------------------------------------------------
# Point the Track B agent runtime here.
export OPENAI_BASE_URL=http://localhost:8000/v1
export OPENAI_API_KEY=$VLLM_API_KEY
export QWEN_MODEL=Qwen/Qwen3.5-35B-A3B
export QWEN_TEMPERATURE=0.0
export QWEN_MAX_TOKENS=1024
export QWEN_TIMEOUT_S=120
export QWEN_RETRIES=1


# ---- Track B tool server (separate from vLLM) -----------------------------
# Production endpoints from data/Phase_2/README.md:
#   ELB (China):   https://120.46.145.77/ip/api/agent/execute
#   HK ECS:        https://124.71.227.61/ip/api/agent/execute
# Local sandbox:   http://localhost:7860/api/agent/execute
export AGENT_TOOL_SERVER_URL= https://120.46.145.77/ip/api/agent/execute #http://localhost:7860/api/agent/execute
export AGENT_TOOL_SERVER_TOKEN=
# Set to 0 if you're hitting the public IPs with self-signed certs.
export AGENT_TOOL_SERVER_VERIFY_TLS=0
export AGENT_TOOL_SERVER_TIMEOUT=25
export AGENT_TOOL_SERVER_RETRIES=2
